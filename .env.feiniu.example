# Installation directory:
# /vol1/1000/docker/jdyk

# Public ports. Change only when the Compose port mappings are changed.
WRJDYK_ADMIN_PUBLIC_PORT=5200
WRJDYK_BACKEND_PUBLIC_PORT=3999

# Feiniu Photos source. The host is discovered through Docker's host gateway.
WRJDYK_PHOTO_SOURCE=feiniu
FEINIU_PHOTOS_PORT=60000
WRJDYK_FEINIU_USERNAME=
WRJDYK_FEINIU_PASSWORD=

# Android TV 1.0 update metadata
WRJDYK_TV_UPDATE_VERSION_CODE=5
WRJDYK_TV_UPDATE_VERSION_NAME=1.0
WRJDYK_TV_UPDATE_SHA256=
WRJDYK_TV_UPDATE_SIZE_BYTES=0
WRJDYK_TV_UPDATE_FORCE=false
WRJDYK_TV_UPDATE_NOTES=Android TV 1.0
WRJDYK_TV_UPDATE_PUBLISHED_AT=
